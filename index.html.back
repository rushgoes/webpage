<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>My Homepage</title>
<style>
    /* 全体のスタイル設定：背景は白、余白をなくして左上に配置 */
    html, body {
        background-color: #ffffff;
        color: #000000;
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
    }

    /* ページ切り替え用のスタイル */
    .page {
        display: none;
    }
    .page.active {
        display: block;
    }

    /* リンク（メニュー）のスタイル */
    a {
        display: block;
        color: #0000ee;
        text-decoration: underline;
        cursor: pointer;
    }

    /* 動画を模したコンテナのスタイル */
    .movie-container {
        width: 320px;
        height: 180px;
        background-color: #000000;
        color: #ffffff;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
    }

    /* スクロールするテキストのアニメーション */
    .scrolling-text {
        position: absolute;
        white-space: nowrap;
        animation: scrollText 4s linear infinite;
    }

    @keyframes scrollText {
        0% { left: 100%; }
        100% { left: -50%; }
    }
</style>
</head>
<body>

    <!-- 1. topページ -->
    <div id="top" class="page active">
        <a onclick="showPage('text')">text</a>
        <a onclick="showPage('picture')">picture</a>
        <a onclick="showPage('movie')">movie</a>
    </div>

    <!-- 2. textページ -->
    <div id="text" class="page">
        <div>Hello World.</div>
        <div>Hello World.</div>
        <div>Hello World.</div>
        <div>Hello World.</div>
        <div>Hello World.</div>
        <div>Hello World.</div>
        <div>Hello World.</div>
        <div>Hello World.</div>
        <div>Hello World.</div>
        <div>Hello World.</div>
        <a onclick="showPage('top')">back</a>
    </div>

    <!-- 3. pictureページ -->
    <div id="picture" class="page">
        <!-- SVG画像を直接埋め込み -->
        <img src="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='100'><rect width='200' height='100' fill='%23eeeeee'/><text x='10' y='55' font-family='sans-serif' font-size='24' fill='%23000000'>Hello World.</text></svg>" alt="Hello World.">
        <a onclick="showPage('top')">back</a>
    </div>

    <!-- 4. movieページ -->
    <div id="movie" class="page">
        <!-- 1ファイルで完結させるためCSSでスクロール動画を表現 -->
        <div class="movie-container">
            <div class="scrolling-text">Hello World.</div>
        </div>
        <a onclick="showPage('top')">back</a>
    </div>

    <script>
        // ページを切り替えるためのJavaScript関数
        function showPage(pageId) {
            // すべてのページを非表示にする
            var pages = document.querySelectorAll('.page');
            for (var i = 0; i < pages.length; i++) {
                pages[i].classList.remove('active');
            }
            // 指定されたページのみを表示する
            document.getElementById(pageId).classList.add('active');
        }
    </script>

</body>
</html>
